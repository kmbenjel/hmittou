1
00:00:16,510 --> 00:00:19,130
جَشَّمْتَنِي النَّظْمَ عَلَى بَحْرٍ عَرَا

2
00:00:19,190 --> 00:00:21,890
مِنَ الْقَوَافِي نَبَذُوهُ بِالْعَرَا

3
00:00:21,950 --> 00:00:24,570
أَوْ هَكَذَا يَبْدُو لِعَيْنَيْ نَاظِرٍ

4
00:00:24,630 --> 00:00:27,829
لِقِلَّةِ الْحَفْلِ بِهِ فِيمَا يُرَى

5
00:00:28,069 --> 00:00:31,050
إِذْ هَجَّنُوهُ فَامْتَطَاهُ كُلُّ مَنْ

6
00:00:31,110 --> 00:00:33,769
رَامَ وَسَمَّوْهُ: "حِمَارَ الشُّعَرَا"

7
00:00:33,829 --> 00:00:36,449
أَلَا تَرَاهُ فِي الْبُحُورِ خَامِلًا

8
00:00:36,509 --> 00:00:39,470
مُمْتَهَنًا بَيْنَ الْقَصِيدِ مُزْدَرَى

9
00:00:40,870 --> 00:00:43,289
مُقْتَرِنًا فِي الذِّهْنِ بِابْنِ عَاشِرٍ

10
00:00:43,349 --> 00:00:45,810
وَبِابْنِ مَالِكٍ وَقَارِئٍ قَرَا

11
00:00:45,870 --> 00:00:48,690
وَمُعْرِبٍ لِقَامَ زَيْدٌ وَأَتَى

12
00:00:48,750 --> 00:00:51,210
عَمْرٌو وَهَمَّ عَامِرٌ بِعُمَرَا

13
00:00:51,270 --> 00:00:53,850
وَحَيْثُمَا فَتَحْتَ دِيوَانًا فَلَا

14
00:00:53,910 --> 00:00:56,910
تُبْصِرُ لِلرَّجَزِ فِيهِ أَثَرَا

15
00:00:57,910 --> 00:01:00,769
قَدْ أَخْمَلُوهُ مِنْ قَدِيمٍ بَيْنَهُمْ

16
00:01:00,829 --> 00:01:03,810
فَلَيْسَ فِي شِعْرِ الْفُحُولِ يُقْتَرَى

17
00:01:03,870 --> 00:01:07,049
قَبْلِي تَخَطَّاهُ الْكِبَارُ فَعُنُوا

18
00:01:07,109 --> 00:01:09,970
بِغَيْرِهِ وَكَادَ أَنْ لَا يُذْكَرَا

19
00:01:10,030 --> 00:01:13,410
إِلَّا أُبَيَّاتًا هُنَا أَوْ هَهُنَا

20
00:01:13,470 --> 00:01:16,870
مِمَّا يَنِدُّ تَارَةً أَنْ يَخْطُرَا

21
00:01:18,270 --> 00:01:21,290
وَفِي الْمُعَلَّقَاتِ لَا ذِكْرَ لَهُ

22
00:01:21,350 --> 00:01:24,329
وَلَا انْتَحَاهُ عُرْوَةٌ وَالشَّنْفَرَى

23
00:01:24,389 --> 00:01:27,210
وَلَا جَرِيرٌ وَالْفَرَزْدَقُ وَلَا الْـ

24
00:01:27,270 --> 00:01:30,049
ـأَخْطَلُ وَالرَّاعِي النُّمَيْرِيُّ اسْتَرَى

25
00:01:30,109 --> 00:01:32,770
وَالْغَزَلُ الْعُذْرِيُّ لَمْ يُلْمِمْ بِهِ

26
00:01:32,830 --> 00:01:35,589
فِي وَصْفِ عَبْلَةَ بِشِعْرِ عَنْتَرَا

27
00:01:36,069 --> 00:01:38,289
وَلَا بِهِ عُرْوَةُ فِي أَقْرَائِهِ

28
00:01:38,349 --> 00:01:41,530
فِي حُبِّ عَفْرَاءَ الْمُحَيَّا عَفَّرَا

29
00:01:41,590 --> 00:01:44,790
وَلَا الْكُمَيْتُ وَجَمِيلٌ وَكُثَيْـ

30
00:01:44,910 --> 00:01:47,009
ـيِرٌ وَمَنْ شَعَرَ فِي أُمِّ الْقُرَى

31
00:01:47,069 --> 00:01:50,110
وَفِي الْكُنَاسَةِ وَسُوقِ مِرْبَدٍ

32
00:01:50,389 --> 00:01:52,969
وَكُلِّ مِصْرٍ قَدْ بَدَا أَوْ حَضَرَا

33
00:01:53,029 --> 00:01:56,009
وَلَوْ تَقَرَّيْتَ الْحِجَازَ وَالشَّآ

34
00:01:56,069 --> 00:01:58,430
مَ وَالْعِرَاقَيْنِ وَمَا تَمَصَّرَا

35
00:01:58,590 --> 00:02:01,490
وَطُفْتَ فِي مِصْرَ وَفِي أَنْدَلُسٍ

36
00:02:01,550 --> 00:02:04,109
وَالْقَيْرَوَانِ مَعْشَرًا فَمَعْشَرَا

37
00:02:04,159 --> 00:02:07,100
فَلَنْ تَرَى لِلْخُلَفَاءِ مَادِحًا

38
00:02:07,159 --> 00:02:09,570
وَلَا الْوُلَاةِ كُلِّهِمْ وَالْوُزَرَا

39
00:02:10,790 --> 00:02:13,090
فَلَنْ تَرَى لِلْخُلَفَاءِ مَادِحًا

40
00:02:13,150 --> 00:02:15,450
وَلَا الْوُلَاةِ كُلِّهِمْ وَالْوُزَرَا

41
00:02:15,510 --> 00:02:18,090
مَنْ أَمَّهُمْ بِرَجَزٍ فَنَالَ مِنْ

42
00:02:18,150 --> 00:02:20,810
عَطَائِهِمْ كَمَا يَنَالُ الشُّعَرَا

43
00:02:20,870 --> 00:02:23,409
فَلَا أَبُو تَمَّامٍ اَوْ قَرِيعُهُ

44
00:02:23,469 --> 00:02:25,570
أَبُو عُبَادَةَ لَهُ قَدْ نَشَرَا

45
00:02:25,630 --> 00:02:28,310
وَلَا أَبُو الطَّيِّبِ فِي مُعْجِزِهِ

46
00:02:28,630 --> 00:02:31,530
قَدَّمَ فِي الْقَوْلِ بِهِ أَوْ أَخَّرَا

47
00:02:31,590 --> 00:02:34,290
وَمُدِحَ الْمُلُوكُ أَدْهَارًا فَمَا

48
00:02:34,350 --> 00:02:37,090
مِنْ أَحَدٍ عَلَى قَرِيِّهِ جَرَى

49
00:02:37,150 --> 00:02:40,090
فَهَلْ أَنَا فِيمَا زَعَمْتُ صَادِقٌ

50
00:02:40,150 --> 00:02:43,389
يَا شَيْخُ يَحْيَى أَوْ أَقَمْتُ الْعُذُرَا؟

51
00:02:45,360 --> 00:02:47,900
فَهَلْ أَنَا فِيمَا زَعَمْتُ صَادِقٌ

52
00:02:47,959 --> 00:02:50,620
يَا شَيْخُ يَحْيَى أَوْ أَقَمْتُ الْعُذُرَا؟

53
00:02:50,670 --> 00:02:53,290
لَوْ شِئْتَ، قُلْتَ: مَا تَرَكْتَ ذِكْرَهُ

54
00:02:53,350 --> 00:02:56,209
مِثْلُ الصَّبَاحِ ظَاهِرٌ لِمَنْ يَرَى

55
00:02:56,269 --> 00:02:58,330
فَأَيْنَ مِنْكَ لَوْ تَقَصَّيْتَ الْمَدَى

56
00:02:58,390 --> 00:03:00,610
شِعْرُ الْمَلَاحِمِ إِذَا الْقِرْنُ انْبَرَى

57
00:03:00,670 --> 00:03:03,389
لِقِرْنِهِ وَاسْتَلَّ مِنْ قِرَابِهِ

58
00:03:03,710 --> 00:03:06,510
حُسَامَهُ وَفِي الْخُطَا تَبَخْتَرَا

59
00:03:08,269 --> 00:03:10,730
وَقَالَ فِي ارْتِجَازِهِ مِنْ مِثْلِ مَا

60
00:03:10,790 --> 00:03:13,530
قَالَ أَبُو السِّبْطَيْنِ يَوْمَ خَيْبَرَا

61
00:03:13,590 --> 00:03:16,049
لَمَّا دَعَا إِلَى الْمِصَاعِ قِرْنَهُ:

62
00:03:16,109 --> 00:03:18,769
"أَنَا الَّذِي سَمَّتْنِ أُمِّي حَيْدَرَا!"

63
00:03:18,829 --> 00:03:21,330
وَقَالَ: "لَمَّا أَنْ رَأَيْتُ مُنْكَرًا

64
00:03:21,390 --> 00:03:24,460
أَجَّجْتُ نَارِي وَدَعَوْتُ قَنْبَرَا"

65
00:03:25,710 --> 00:03:27,890
وَابْنُ رَوَاحَةَ بِيَوْمِ خَنْدَقٍ

66
00:03:27,950 --> 00:03:30,250
وَغَيْرِهِ كَمْ فِيهِ عَنْهُ أُثِرَا

67
00:03:30,310 --> 00:03:32,170
وَمَنْ تَأَمَّلَ فُصُولَ سِيرَةٍ

68
00:03:32,230 --> 00:03:34,259
لِابْنِ هِشَامٍ سَيَرَاهُ أَوْفَرَا

69
00:03:35,189 --> 00:03:37,290
وَفِي الْفُتُوحِ لَمْ يَزَلْ يُنْشِدُهُ

70
00:03:37,350 --> 00:03:39,610
كَمْ بَطَلٍ بَيْنَ الصُّفُوفِ افْتَخَرَا

71
00:03:39,670 --> 00:03:41,849
وَكَانَ بَيْنَ الْعُرْبِ فَنًّا رَاقِيًا

72
00:03:41,909 --> 00:03:44,129
مُسْتَطْرَفًا عَلَى الْقَرِيضِ مُسْتَرَى

73
00:03:44,189 --> 00:03:46,209
يَوْمَ اسْتَجَادُوهُ وَأَعْلَوْا شَأْوَهُ

74
00:03:46,269 --> 00:03:49,070
فَقِيلَ: "كُلُّ الصَّيْدِ فِي جَوْفِ الْفَرَا!"

75
00:03:50,670 --> 00:03:52,890
وَعَادَ شِعْرُ الطَّرْدِ مِنْ أَشْرَفِ مَا

76
00:03:52,950 --> 00:03:55,329
تَنَافَسَتْ فِيهِ الْبَوَادِي وَالْقُرَى

77
00:03:55,389 --> 00:03:57,730
وَبَاتَ عِنْدَ أَهْلِهِ مُنْتَخَبًا

78
00:03:57,790 --> 00:04:00,129
لِوَصْفِ صَيْدٍ وَقَنِيصٍ يُدَّرَى

79
00:04:00,189 --> 00:04:02,650
يَنْتَابُ أَسْرَابَ الْمَهَا فِي بِيدِهَا

80
00:04:02,710 --> 00:04:04,969
وَيَنْتَحِي الْغِزْلَانَ فِي وَادِي الْقُرَى

81
00:04:05,029 --> 00:04:07,530
وَكَانَتِ الْمُلُوكُ إِنْ تَاقَتْ لَهُ

82
00:04:07,590 --> 00:04:09,689
دَعَتْ لَهُ مُفَضَّلًا وَالْأَحْمَرَا

83
00:04:09,749 --> 00:04:11,849
وَالْأَصْمَعِيَّ وَأَبَا عَمْرٍو وَمَنْ

84
00:04:11,909 --> 00:04:14,790
يُدْعَى أَبَا عُبَيْدَةٍ مُعَمَّرَا

85
00:04:15,109 --> 00:04:17,249
وَمَنْ رَوَى الْأَرْجَازَ عَنْ أَعْرَابِهَا

86
00:04:17,309 --> 00:04:20,050
وَخَالَطُوهُمْ فِي السِّفَارِ وَالسُّرَى

87
00:04:20,110 --> 00:04:22,450
وَكَانَ فِي الْبَدْوِ لَهُ فَطَاحِلٌ

88
00:04:22,510 --> 00:04:24,930
قَدْ نَافَسُوا فِيهِ وَطَاوَلُوا الذُّرَى

89
00:04:24,990 --> 00:04:27,490
وَالْأَغْلَبُ الْعِجْلِيُّ فِي أَرْجَازِهِ

90
00:04:27,550 --> 00:04:29,730
قَدْ جَاءَ فِي الْوَصْفِ بِمَا بَذَّ الْوَرَى

91
00:04:29,790 --> 00:04:31,490
سَأَلَهُ عُمَرُ أَنْ يُنْشِدَهُ

92
00:04:31,550 --> 00:04:34,230
فَقَالَ: قَدْ سَأَلْتَ خَيْرًا مُحْضَرَا

93
00:04:34,589 --> 00:04:36,610
وَإِنَّمَا أَرَادَ أَنْ يَخْبُرَهُ

94
00:04:36,670 --> 00:04:39,050
فَوَافَقَ الْخُبْرُ لَدَيْهِ الْخَبَرَا

95
00:04:39,110 --> 00:04:41,809
وَكَانَ قَدْ سَنَّ الْأَرَاجِيزَ الطِّوَا

96
00:04:41,869 --> 00:04:43,929
لَ كَالْقَصَائِدِ بِهِنَّ اشْتَهَرَا

97
00:04:43,989 --> 00:04:46,089
وَالرَّاجِزُ الْعَجَّاجُ فِي آثَارِهِ

98
00:04:46,149 --> 00:04:48,770
قَدْ جَاءَ فِي الْأَرْجَازِ يَقْفُو الْأَثَرَا

99
00:04:48,830 --> 00:04:50,610
فَكَانَ يَقْفُو أَثَرَ الْعِجْلِيِّ فِي

100
00:04:50,670 --> 00:04:53,550
مَيْدَانِهِ وَفِي عِنَانِهِ جَرَى

101
00:04:54,270 --> 00:04:56,369
وَجَاءَ مِنْهُ بِالَّتِي مَطْلَعُهَا:

102
00:04:56,429 --> 00:04:58,770
"قَدْ جَبَرَ الدِّينَ الْإِلَهُ" جَبَرَا

103
00:04:58,830 --> 00:05:00,890
وَرُؤبَةٌ فِي "قَاتِمِ الْأَعْمَاقِ خَا

104
00:05:00,950 --> 00:05:04,050
وِي" قَدْ تَلَا ذَاكَ السَّبِيلَ وَاقْتَرَى

105
00:05:04,110 --> 00:05:06,089
فَغَاصَ فِي اللُّغَى عَلَى مُعْتَاصِهَا

106
00:05:06,149 --> 00:05:08,789
فَبَاعَ مِنْهَا فِي الْغَرِيبِ وَاشْتَرَى

107
00:05:09,110 --> 00:05:11,210
وَلِأَبِي النَّجْمِ أَخِي عِجْلٍ بِهِ

108
00:05:11,270 --> 00:05:13,890
مَا لَيْسَ يَشْأُو شَأْوَهُ مَنْ شَعَرَا

109
00:05:13,950 --> 00:05:15,970
وَكَانَ فِي عَهْدِ بَنِي أُمَيَّةٍ

110
00:05:16,030 --> 00:05:17,850
مُقَدَّمًا فِي ذَاكَ بَيْنَ الشُّعَرَا

111
00:05:17,910 --> 00:05:20,050
قَدْ جَاءَ ثَالِثَ الثَّلَاثَةِ الْأُلَى

112
00:05:20,110 --> 00:05:22,929
قَدْ ذَلَّلُوهُ مَوْرِدًا وَصَدَرَا

113
00:05:22,989 --> 00:05:25,529
وَكَمْ وَكَمْ مِنْ رَاجِزٍ فَحْلٍ وَكَمْ

114
00:05:25,589 --> 00:05:27,809
مِنْ حَادِ أَيْنُقٍ بِهِ الْبِيدَ فَرَى

115
00:05:27,869 --> 00:05:29,770
مِمَّنْ رَوَى الْأَرْجَازَ عَنْ رُوَاتِهَا

116
00:05:29,830 --> 00:05:32,789
أَهْلِ الْعِمَادِ وَتَبَدَّى فِي الْبَرَى

117
00:05:32,910 --> 00:05:35,209
وَسَمِعَ الْعَرَبَ فِي أَمْثَالِهَا:

118
00:05:35,269 --> 00:05:37,770
"عِنْدَ الصَّبَاحِ يَحْمَدُ الْقَوْمُ السُّرَى"

119
00:05:37,830 --> 00:05:40,410
وَقَوْلَهُمْ: "شَكَا إِلَيَّ جَمَلِي

120
00:05:40,470 --> 00:05:43,330
طُولَ السُّرَى" إِذْ طَالَمَا بِهِ سَرَى

121
00:05:43,390 --> 00:05:46,050
وَقَوْلَ مَنْ قَالَ لِمُبْدٍ كِبْرَهُ:

122
00:05:46,110 --> 00:05:49,349
"أَطْرِقْ كَرَا، إِنَّ النَّعَامَ فِي الْقُرَى!"

123
00:05:50,750 --> 00:05:52,850
وَلَمْ يَزَلْ وَالشُّعَرَاءُ تَنْتَخِي

124
00:05:52,910 --> 00:05:56,110
بِالْحِذْقِ فِيهِ فَتُثِيرُ الْعِثْيَرَا

125
00:05:56,310 --> 00:05:58,089
فَلَمْ تَكُنْ بَغْدَادُ خِلْوًا مِنْهُ فِي

126
00:05:58,149 --> 00:06:00,490
أَيَّامِهَا حِينَ الْقَصِيدُ ازْدَهَرَا

127
00:06:00,550 --> 00:06:02,970
فَلِلْعَتَاهِيِّ بِهِ بَدَائِعٌ

128
00:06:03,030 --> 00:06:05,529
فِي الزُّهْدِ حَلَّقَ بِهَا وَاسْتَأْثَرَا

129
00:06:05,589 --> 00:06:07,970
وَلِلنُّوَاسِيِّ رَوَائِعُ بِهَا

130
00:06:08,030 --> 00:06:10,489
فِي الْقَنْصِ وَالطِّرَادِ قَدْ تَصَدَّرَا

131
00:06:10,549 --> 00:06:12,690
وَلِابْنِ مُعْتَزٍّ وَحَاذٍ حَذْوَهُ

132
00:06:12,750 --> 00:06:15,590
مِنْ أَهْلِ بَغْدَادَ "وَسُرَّ مَنْ يَرَى"

133
00:06:16,989 --> 00:06:19,529
وَابْنُ دُرَيْدٍ صَاغَ مَقْصُورَتَهُ

134
00:06:19,589 --> 00:06:22,290
فَفَاقَ فِيهَا مَنْ بَدَا أَوْ حَضَرَا

135
00:06:22,350 --> 00:06:25,369
"يَا ظَبْيَةً أَشْبَهَ شَيْءٍ بِالْمَهَا!"

136
00:06:25,429 --> 00:06:27,929
أَعْجَزَ فِيهَا فِي الْقَرِيضِ مَنْ دَرَى

137
00:06:27,989 --> 00:06:30,130
وَلَمْ يَكُ الرَّجَزُ فِي يَوْمٍ لَقًى

138
00:06:30,190 --> 00:06:32,369
مُسْتَرْذَلًا أَوْ كَانَ نِسْيًا فِي الثَّرَى

139
00:06:32,429 --> 00:06:34,489
بَلْ زَاحَمَ الْقَصِيدَ حَتَّى جَازَهُ

140
00:06:34,549 --> 00:06:36,330
مَكَانَةً وَصَارَ مِنْهُ أَسْيَرَا

141
00:06:36,390 --> 00:06:38,089
وَكَانَ فِي الْمَغْرِبِ أَوْ أَنْدَلُسٍ

142
00:06:38,149 --> 00:06:40,950
مِنْهُ الْبَدِيعُ أَزْمُنًا وَأَعْصُرَا

143
00:06:41,510 --> 00:06:44,369
وَحَازِمُ الْقَرْطَاجَنِي بِتُونِسٍ

144
00:06:44,429 --> 00:06:47,050
قَدْ حَاكَ مَقْصُورَتَهُ مَا قَصَّرَا

145
00:06:47,110 --> 00:06:49,209
لَكِنَّهُ قَدْ عُدَّ غَيْرَ حَازِمٍ

146
00:06:49,269 --> 00:06:51,330
لَمَّا بِهَا قَدْ قَصَدَ الْمُسْتَنْصِرَا

147
00:06:51,390 --> 00:06:53,450
فَعَابَهُ بِذَا الْمَكُودِيُّ وَلَمْ

148
00:06:53,510 --> 00:06:56,170
يَعِبْ قَرِيضَهُ الَّذِي قَدْ بَهَرَا

149
00:06:56,230 --> 00:06:58,529
أَمَّا الْمَكُودِيُّ فَجَادَ صَنْعَةً

150
00:06:58,589 --> 00:07:01,209
وَزَادَ إِذْ مَمْدُوحُهُ خَيْرُ الْوَرَى

151
00:07:01,269 --> 00:07:03,970
صَلَّى عَلَيْهِ اللَّهُ مَا لَيْلٌ دَجَا

152
00:07:04,030 --> 00:07:06,290
وَجَاءَ صُبْحٌ بَعْدَهُ فَنَوَّرَا

153
00:07:06,350 --> 00:07:08,209
وَلِلشَّمَقْمَقِ ابْنِ وَنَّانٍ بِهِ

154
00:07:08,269 --> 00:07:10,089
قَافِيَةٌ لِقَافِهَا قَدْ كَسَرَا

155
00:07:10,149 --> 00:07:12,649
مُخَاطِبًا حَادِيَهُ: "مَهْلًا عَلَى

156
00:07:12,709 --> 00:07:15,710
رِسْلِكَ حَادِي" أَيْنُقٍ تَهَوَّرَا

157
00:07:17,190 --> 00:07:19,450
وَلِلرِّبَاطِيِّ أَبِي عَمْرٍو لَهَا

158
00:07:19,510 --> 00:07:21,929
أُخْتٌ تَقَفَّى قَافَهَا وَاقْتَفَرَا

159
00:07:21,989 --> 00:07:24,089
فَجَاءَ بِالسَّهْلِ الَّذِي يَأْبَى عَلَى

160
00:07:24,149 --> 00:07:26,909
مَنْ رَامَهُ وَلَوْ تَعَنَّى وَاجْتَرَا

161
00:07:26,989 --> 00:07:29,489
فَهَذِهِ قَلَائِدُ الْأَرْجَازِ قَدْ

162
00:07:29,549 --> 00:07:32,369
فَاقَتْ قَلَائِدَ الْحِسَانِ وَالْبُرَى

163
00:07:32,429 --> 00:07:35,130
فَأَيْنَ مِنْهَا مَا تَرَانِي نَاظِمًا

164
00:07:35,190 --> 00:07:37,890
وَهَلْ تُسَوِّي بِالْجُمَانِ الْحَجَرَا

165
00:07:37,950 --> 00:07:40,209
مَاذَا يَقُولُ شَاعِرٌ إِنْ شَعَرَا

166
00:07:40,269 --> 00:07:43,010
رَأَيْتَ فِي بُحُورِهِ مَا لَا يَرَى

167
00:07:43,070 --> 00:07:45,649
أَنْشَدْتُهُ مِنْ نَظْمِهِ مَا لَمْ يَعُدْ

168
00:07:45,709 --> 00:07:48,049
يَذْكُرُهُ وَوَدَّ لَوْ تَذَكَّرَا

169
00:07:48,109 --> 00:07:50,369
مَضَيْتَ فِيهِ حَافِظًا لَهُ كَمَا

170
00:07:50,429 --> 00:07:53,430
لَوْ كَانَ مِنْ آيِ الْكِتَابِ سُوَرَا

171
00:07:53,709 --> 00:07:56,010
مَا بَيْنَ بَحْرٍ كَامِلٍ وَوَافِرٍ

172
00:07:56,070 --> 00:07:58,130
وَرَمَلٍ وَمِنْ بُحُورٍ أُخَرَا

173
00:07:58,190 --> 00:08:00,610
وَحِينَمَا افْتَقَدْتَ فِيهِ رَجَزًا

174
00:08:00,670 --> 00:08:02,929
لَمْ تَرَهُ مِنْ بَيْنِهَا مُعْتَبَرَا

175
00:08:02,989 --> 00:08:05,330
سَأَلْتَنِيهِ وَعَدَدْتَ مَنْ جَفَا

176
00:08:05,390 --> 00:08:07,730
عَنْهُ كَمَنْ أَزْرَى بِهِ وَاسْتَحْقَرَا

177
00:08:07,790 --> 00:08:09,890
وَخِلْتَ أَنِّي قَدْ هَضَمْتُ حَقَّهُ

178
00:08:09,950 --> 00:08:12,489
هَجْرًا وَمَا مِنْ حَقِّهِ أَنْ يُهْجَرَا

179
00:08:12,549 --> 00:08:14,290
فَقُلْتُ: لَا عَتْبَ عَلَيَّ إِنَّنِي

180
00:08:14,350 --> 00:08:16,970
قَدْ سُقْتُ عُذْرِي ظَاهِرًا مُفَسَّرَا

181
00:08:17,030 --> 00:08:18,890
لَمَّا رَأَيْتُ الشُّعَرَاءَ نَظَمُوا

182
00:08:18,950 --> 00:08:21,450
فِيهِ السِّخَابَ وَالْحَصَى وَالْبَعَرَا

183
00:08:21,510 --> 00:08:24,570
هَجَرْتُهُ هُجْرَانَ قَالٍ أَوْ فَقُلْ

184
00:08:24,630 --> 00:08:27,209
هُجْرَانَ زَاهِدٍ بِهِ مُسْتَصْغِرَا

185
00:08:27,269 --> 00:08:29,250
وَالْآنَ قَدْ صَالَحْتُهُ مِنْ أَجْلِ مَنْ

186
00:08:29,310 --> 00:08:31,710
شَفَعَ فِيهِ رَاغِبًا وَمُؤْثِرَا

187
00:08:31,869 --> 00:08:34,130
قُلْ لِأَبِي عَبْدِ الرَّحِيمِ الْمُرْتَضَى:

188
00:08:34,190 --> 00:08:36,770
طِبْتَ حِلَالًا فِي سَلَا وَمَحْضَرَا

189
00:08:36,830 --> 00:08:39,130
أَهْلًا بِنَا وَبِكَ فِي وَادِي سَلَا

190
00:08:39,190 --> 00:08:41,489
مَنْ حَلَّ وَادِيهِ سَلَا عَمَّنْ وَرَا

191
00:08:41,549 --> 00:08:43,970
قَدْ صَارَ مَا أَمَّلْتَ أَمْرًا وَاقِعًا

192
00:08:44,030 --> 00:08:46,330
حَقًّا وَمَا كَانَ حَدِيثًا يُفْتَرَى

193
00:08:46,390 --> 00:08:48,970
مِنْ فَاضِلٍ مِنْ مَطْلَعِ الشَّمْسِ سَرَى

194
00:08:49,030 --> 00:08:51,130
لَيْلًا وَفِي صَبَاحِهِ تَمَصَّرَا

195
00:08:51,190 --> 00:08:53,490
أَتَى سَلَا فَلَمْ يَكَدْ يَثْوِي بِهَا

196
00:08:53,550 --> 00:08:55,610
حَتَّى سَلَا عَنْ كُلِّ رَبْعٍ عَمَّرَا

197
00:08:55,670 --> 00:08:57,969
ذَاقَ نَمِيرَ نَهْرِهَا فَلَمْ يَعُدْ

198
00:08:58,029 --> 00:09:00,989
يَشْفِي صَدَاهُ غَيْرُ مَا مِنْهُ جَرَى

199
00:09:02,190 --> 00:09:04,250
وَلَا يَلَذُّ مَطْعَمًا فِي غَيْرِهَا

200
00:09:04,310 --> 00:09:06,610
أَوْ نَسْمَةً يَشْتَمُّهَا أَوْ بِكَرَى

201
00:09:06,670 --> 00:09:08,650
فَمَرْحَبًا بِكَ حَلَلْتَ مَنْزِلًا

202
00:09:08,710 --> 00:09:10,770
سَهْلًا فَفَاحَ مَنْدَلًا وَعَنْبَرَا

203
00:09:10,830 --> 00:09:12,810
وَلَا تَزَلْ وَالْيُمْنُ فِي أَكْنَافِهِ

204
00:09:12,870 --> 00:09:15,169
وَالْأَمْنُ وَالْأَمَانُ مَوْصُولُ الْعُرَى

205
00:09:15,229 --> 00:09:17,810
يَا شَيْخُ يَحْيَى فَخْرَ فَيْفَاءَ الَّذِي

206
00:09:17,870 --> 00:09:20,330
بِهِ تُبَاهِي وَتَتِيهُ مَفْخَرَا

207
00:09:20,390 --> 00:09:22,210
لِيَهْنِكَ الْفَرْعُ الَّذِي تُعْزَى لَهُ

208
00:09:22,270 --> 00:09:25,130
مِنْكَ الْأُصُولُ الرَّاسِخَاتُ فِي الثَّرَى

209
00:09:25,190 --> 00:09:27,169
وَالْمُنْتَمِي فِي خَيْرِمَا أُرُومَةٍ

210
00:09:27,229 --> 00:09:29,729
فِي الْجِذْمِ مِنْ قَحْطَانَ آسَادِ الشَّرَى

211
00:09:29,789 --> 00:09:31,690
مِنْ بَطْنِ خَوْلَانَ طَلَعْتَ مَاجِدًا

212
00:09:31,750 --> 00:09:33,729
مِنْ مَاجِدِينَ فُضَلَاءَ كُبَرَا

213
00:09:33,789 --> 00:09:35,570
مِنْ يَحْصُبٍ وَيَشْجُبٍ وَيَعْرُبٍ

214
00:09:35,630 --> 00:09:37,650
وَذِي رُعَيْنٍ وَمُلُوكِ حِمْيَرَا

215
00:09:37,710 --> 00:09:39,890
وَكَانَ مِنْهُمْ لِلنَّبِيِّ الْمُصْطَفَى

216
00:09:39,950 --> 00:09:42,050
مِنْ صَحْبِهِ الْأَنْصَارُ خَيْرُ النُّصَرَا

217
00:09:42,110 --> 00:09:44,690
فَاهْنَأْ فَقَدْ جَمَعْتَ مَجْدًا طَارِفًا

218
00:09:44,750 --> 00:09:46,969
إِلَى تَلِيدٍ حُزْتَ مِنْهُ الْجَوْهَرَا

219
00:09:47,029 --> 00:09:48,969
ثُمَّ هَنِيئًا يَا ابْنَ أَسْعَدَ بِمَا

220
00:09:49,029 --> 00:09:51,050
حَلَلْتَ فِي سَلَا وَطِبْتَ عُمُرَا

221
00:09:51,110 --> 00:09:53,650
قَدْ شَمَخَتْ بِكَ سَلَا إِذْ صِرْتَ مِنْ

222
00:09:53,710 --> 00:09:55,650
أَعْلَامِهَا وَمَنْ لَهَا قَدْ عَمَرَا

223
00:09:55,710 --> 00:09:57,810
وَزِدْتَ فَخْرًا وَمَقَامًا بِالَّذِي

224
00:09:57,870 --> 00:10:00,429
أَحْرَزْتَ مِنْ مَشْيَخَةٍ وَمُقْتَرَا

225
00:10:00,510 --> 00:10:02,610
وَصَارَ مِنْ حَقِّ الْعُلَا أَنْ تَحْتَفِي

226
00:10:02,670 --> 00:10:04,770
بِمَا ازْدَهَى بِهِ الْحِمَى وَازْدَهَرَا

227
00:10:04,830 --> 00:10:06,770
لَدُنْ حَلَلْتَ فِي الدِّيَارِ طَالِبًا

228
00:10:06,830 --> 00:10:09,470
فَكُنْتَ بَدْرًا طَالِعًا وَقَمَرَا

229
00:10:10,789 --> 00:10:13,050
وَصِرْتَ فِي أَوَّلِ مَنْ نَعُدُّهُ

230
00:10:13,110 --> 00:10:15,289
إِذَا عَدَدْنَا مَنْ عَلَى الشَّيْخِ قَرَا

231
00:10:15,349 --> 00:10:17,409
أَعْنِي السَّحَابِيَّ الْجَلِيلَ مَنْ بِهِ

232
00:10:17,469 --> 00:10:19,490
نَوَّهْتَ فِي الْمَشْرِقِ حَتَّى اشْتَهَرَا

233
00:10:19,550 --> 00:10:21,450
فَأَكْبَرُ الْفَضْلِ إِلَيْكَ يَنْتَهِي

234
00:10:21,510 --> 00:10:24,030
وَكَانَ فَضْلُهُ عَلَيْكَ الْأَكْبَرَا

235
00:10:25,349 --> 00:10:27,450
بِمَا عَنِ السَّبْعَةِ مِنْ قِرَاءَةٍ

236
00:10:27,510 --> 00:10:29,849
رَوَّاكَ ثُمَّ زَادَهَا فَعَشَّرَا

237
00:10:29,909 --> 00:10:32,409
صُغْرَى وَكُبْرَى وَالَّتِي لِنَافِعٍ

238
00:10:32,469 --> 00:10:34,729
مِنْ طُرْقِ تَعْرِيفٍ وَتَفْصِيلٍ دَرَى

239
00:10:34,789 --> 00:10:36,770
حَتَّى تَمَلَّأْتَ بِمَا أَسْنَدْتَهُ

240
00:10:36,830 --> 00:10:39,010
عَنْهُ وَكُنْتَ الْفَائِزَ الْمُظَفَّرَا

241
00:10:39,070 --> 00:10:40,849
خُذْهَا أَبَا عَبْدِ الرَّحِيمِ رَوْضَةً

242
00:10:40,909 --> 00:10:42,930
غَنَّاءَ رَاقَ زَهْرُهَا وَنَوَّرَا

243
00:10:42,990 --> 00:10:44,529
أَوْ كَعَرُوسٍ بَرَزَتْ مِنْ بَعْدَمَا

244
00:10:44,589 --> 00:10:46,289
ظَلَّتْ يُوَارِيهَا الْحِجَابُ أَشْهُرَا

245
00:10:46,349 --> 00:10:48,450
جَلَوْتُهَا عَلَيْكَ فِي مِنَصَّةٍ

246
00:10:48,510 --> 00:10:51,010
لَفَّتْ حَيَاءً وَجْهَهَا أَنْ تُبْصَرَا

247
00:10:51,070 --> 00:10:52,969
مَا ضَرَّهَا أَنْ لَمْ يَكُنْ مُنْشِئُهَا

248
00:10:53,029 --> 00:10:55,610
يُدْعَى أَبَا النَّجْمِ أَوِ الْقَبَعْثَرَى

249
00:10:55,670 --> 00:10:57,610
أَوْ لَمْ تَكُنْ فِي نَفْحِ طِيبٍ أَوْ مَقَا

250
00:10:57,670 --> 00:11:00,529
مَاتِ الْحَرِيرِي أَوْ لَدَى زَمَخْشَرَا

251
00:11:00,589 --> 00:11:02,570
أَنْتَ الَّذِي جَشَّمْتَنِيهَا فَلْتَكُنْ

252
00:11:02,630 --> 00:11:05,450
عَيْنُ الرِّضَا تُغْمِضُ عَمَّا كَدَرَا

253
00:11:05,510 --> 00:11:07,529
وَإِنْ تَكُ الْأُخْرَى فَتِلْكَ مُكْنَتِي

254
00:11:07,589 --> 00:11:09,490
وَلَا يُلَامُ مَنْ أَتَى مَا قَدَرَا

255
00:11:09,550 --> 00:11:11,650
مَا قُلْتُهُ فِيكَ حَرٍ أَنْ يُزْبَرَا

256
00:11:11,710 --> 00:11:14,350
بِالذَّهَبِ الْإِبْرِيزِ ثُمَّ يُنْشَرَا

257
00:11:15,630 --> 00:11:18,250
لِلصِّدْقِ فِيهِ وَالْوَفَاءِ مَوْضِعٌ

258
00:11:18,310 --> 00:11:20,610
مَا كَانَ يَخْفَى خَبَرًا وَمَخْبَرَا

259
00:11:20,670 --> 00:11:22,849
كَمْ لِيَ مِنْ قَافِيَةٍ حَبَّرْتُهَا

260
00:11:22,909 --> 00:11:24,930
فَكِدْتُ أَسْتَوْعِبُ فِيهَا الْأَبْحُرَا

261
00:11:24,990 --> 00:11:27,330
كَمْ وَافِرٍ كَمْ كَامِلٍ كَمْ رَمَلٍ

262
00:11:27,390 --> 00:11:29,289
كَمْ مِنْ خَفِيفٍ وَبَسِيطٍ سُطِرَا

263
00:11:29,349 --> 00:11:31,250
كَمْ قُلْتُ فِي فَيْفَاءَ مِنْ قَصِيدَةٍ

264
00:11:31,310 --> 00:11:33,810
عَصْمَاءَ فِيهِنَّ الْبَهَاءُ بَهَرَا

265
00:11:33,870 --> 00:11:35,930
لَكِنَّنِي مِنْ غَيْرِ قَصْدٍ لَمْ أَصُغْ

266
00:11:35,990 --> 00:11:37,890
فِي رَجَزٍ أَوْ هَزَجٍ كَمَا تَرَى

267
00:11:37,950 --> 00:11:40,169
فَخُذْ إِلَيْكَ هَذِهِ يَتِيمَةً

268
00:11:40,229 --> 00:11:43,090
رَقَّتْ وَرَاقَتْ فِي رَوِيِّ حَرْفِ "رَا"

269
00:11:43,150 --> 00:11:45,210
وَلَا تَسُمْنِي بَعْدَهَا فِي رَجَزٍ

270
00:11:45,270 --> 00:11:47,499
فَلَسْتُ أَمْتَطِي حِمَارَ الشُّعَرَا!

271
00:12:05,229 --> 00:12:08,450
يَا شَيْخُ يَحْيَى لَوْ أَعَدْتَ النَّظَرَا

272
00:12:08,510 --> 00:12:11,570
رَأَيْتَ فِي الرَّجَزِ مِثْلَمَا أَرَى

273
00:12:11,630 --> 00:12:14,549
فَالشِّبْهُ نَحْوُ شِبْهِهِ مُنْجَذِبٌ

274
00:12:14,710 --> 00:12:17,630
فَلَا تَقُلْ لِي قَدْ ظَلَمْتُ الْحُمُرَا!

275
00:12:19,029 --> 00:12:22,169
وَلَا تَقُلْ فِي رَجَزٍ إِلَّا كَمَا

276
00:12:22,229 --> 00:12:24,849
تَقُولُ فِي الْعَيْرِ إِذَا الْعَيْرُ جَرَى

277
00:12:24,909 --> 00:12:28,289
كِلَاهُمَا مُسْتَهْجَنٌ لَسْتَ تَرَى

278
00:12:28,349 --> 00:12:31,870
مِنْ جِنْسِهِ إِلَّا ثَقِيلًا مُزْدَرَى

279
00:12:32,510 --> 00:12:35,330
ثُمَّ أَجِدْ سَمْعًا فَقَابِلْهُ بِمَا

280
00:12:35,390 --> 00:12:38,810
مِنَ الْفَضَائِلِ لَهُ قَدْ ذُكِرَا

281
00:12:38,870 --> 00:12:42,010
وَهَا أَنَا أُشَنِّفُ السَّمْعَ فَخُذْ

282
00:12:42,070 --> 00:12:45,310
عَنِّيَ مَا فِي كُلِّ سَمْعٍ وَقَرَا

283
00:12:46,909 --> 00:12:50,109
مِمَّا بِهِ قَدْ نَطَقَتْ بِنَصِّهِ

284
00:12:50,270 --> 00:12:53,169
آيُ الْكِتَابِ، وَلَهَا الْكُلُّ قَرَا

285
00:12:53,229 --> 00:12:55,930
وَمَا بِهِ السُّنَّةُ قَدْ تَوَاتَرَتْ

286
00:12:55,990 --> 00:12:59,190
وَالسِّيرَةُ الْغَرَّاءُ، فَاتْلُ السِّيَرَا

287
00:12:59,710 --> 00:13:02,210
وَمَا بِهِ الْعَرَبُ فِي أَمْثَالِهَا

288
00:13:02,270 --> 00:13:05,330
قَدْ نَوَّهَتْ، وَقَالَ فِيهِ الشُّعَرَا

289
00:13:05,390 --> 00:13:08,570
وَلَسْتُ فِي كُلِّ حِمَارٍ رَاغِبًا

290
00:13:08,630 --> 00:13:12,289
سَمَّوْهُ عَيْرًا أَوْ حِمَارًا أَوْ فَرَا

291
00:13:12,349 --> 00:13:15,289
لَكِنَّنِي يَا شَيْخُ يَحْيَى أَبْتَغِي

292
00:13:15,349 --> 00:13:18,330
رِضَاكَ، لَيْسَ لِأَزِيدَ فِي الْمِرَا

293
00:13:18,390 --> 00:13:22,229
وَإِنَّمَا لِكَيْ أَكُونَ مُنْصِفًا

294
00:13:26,110 --> 00:13:29,390
إِذَا بَسَطْتُ الْقَوْلَ فِيهِ مُعْذِرَا

295
00:13:30,990 --> 00:13:33,930
وَجِئْتُ فِي أَمْرِ الْحَمِيرِ كُلِّهِمْ

296
00:13:33,990 --> 00:13:37,210
بِمَا لَهُمْ وَمَا عَلَيْهِمْ مُخْبِرَا

297
00:13:37,270 --> 00:13:40,089
أَمَّا الَّذِي لَهُمْ فَمِنْ خِلَافِهِ

298
00:13:40,149 --> 00:13:43,349
تَعْرِفُهُ إِنْ تَكُ بَعْدُ مُنْكِرَا

299
00:13:43,870 --> 00:13:46,610
شَأْنُ الْحِمَارِ الْحَمْلُ وَالرُّكُوبُ وَالْـ

300
00:13:46,670 --> 00:13:49,650
ـحَرْثُ، وَجَرُّ الْعَرَبَاتِ فِي الْقُرَى

301
00:13:49,710 --> 00:13:52,930
كَالدَّوْرِ بِالرَّحَى وَدَرْسٍ لِلزُّرُو

302
00:13:52,990 --> 00:13:55,529
عِ وَالْبُذُورِ وَأُمُورٍ أُخَرَا

303
00:13:55,589 --> 00:13:57,729
"وَالْخَيْلَ وَالْبِغَالَ وَالْحَمِيرَ" مِمْـ

304
00:13:57,789 --> 00:14:01,310
ـمَا رَبُّنَا لِمِثْلِ ذَاكَ سَخَّرَا

305
00:14:02,789 --> 00:14:05,330
"لِتَرْكَبُوهَا"، ثُمَّ قَالَ: "زِينَةً"

306
00:14:05,390 --> 00:14:08,570
لِلنَّاظِرِينَ حِلْيَةً وَمَنْظَرَا

307
00:14:08,630 --> 00:14:11,529
لَكِنَّمَا الْحَمِيرُ أَدْنَى رُتْبَةً

308
00:14:11,589 --> 00:14:14,590
لِذَاكَ جَاءَ ذِكْرُهَا مُؤَخَّرَا

309
00:14:15,349 --> 00:14:18,450
وَلَا تَرَى فِي النَّاسِ مَنْ يَخْتَارُهَا

310
00:14:18,510 --> 00:14:21,649
إِنْ كَانَ قَدْ خَيَّرَهُ مَنْ خَيَّرَا

311
00:14:21,709 --> 00:14:24,950
فَالْمَشْيُ رَاجِلًا بِلَا مَطِيَّةٍ

312
00:14:25,430 --> 00:14:28,909
وَلَا رُكُوبٌ فِي السِّفَارِ الْحُمُرَا

313
00:14:29,310 --> 00:14:33,010
إِنَّ الْحِمَارَ شَرُّ ظَهْرٍ يُمْتَطَى

314
00:14:33,070 --> 00:14:35,810
وَشَرُّ مَرْكُوبٍ لِمَنْ يَبْغِي السُّرَى

315
00:14:35,870 --> 00:14:38,849
يَمْشِي مُرَاوِحًا مَكَانَهُ فَإِنْ

316
00:14:38,909 --> 00:14:42,529
أَبْصَرْتَهُ تَخَالُهُ يَمْشِي وَرَا

317
00:14:42,589 --> 00:14:44,810
وَلَوْ مَعَ الْجِيَادِ سَارَ سَاعَةً

318
00:14:44,870 --> 00:14:48,169
لَقَالَ: هَاتُوا لِي سِمَاطًا أَخْضَرَا!

319
00:14:48,229 --> 00:14:50,610
فَنَافَسَ الْجِيَادَ فِي مِضْمَارِهَا

320
00:14:50,670 --> 00:14:52,969
لَكِنَّهُ سُرْعَانَ مَا تَدَهْوَرَا

321
00:14:53,029 --> 00:14:55,789
وَإِنْ تُرِدْ مِنْهُ الْمَزِيدَ زَاجِرًا

322
00:14:57,029 --> 00:14:59,490
صَارَ الَّذِي أَنْكَرْتَ مِنْهُ أَكْثَرَا

323
00:14:59,550 --> 00:15:02,370
وَإِنْ تَزِدْ فِي حَفْزِهِ بِوَخْزِهِ

324
00:15:02,430 --> 00:15:05,710
ظَنَّكَ تَسْتَوْقِفُهُ فَقَصَّرَا

325
00:15:06,070 --> 00:15:08,590
وَإِنْ حَمَلْتَهُ عَلَى تَقَدُّمٍ

326
00:15:08,750 --> 00:15:11,370
خَالَكَ تَسْتَأْخِرُهُ فَاسْتَأْخَرَا

327
00:15:11,430 --> 00:15:14,450
يَمْشِي الْهُوَيْنَى وَيَرَاهُ سُنَّةً

328
00:15:14,510 --> 00:15:17,590
فَهْوَ إِذَا سَارَ تَقَفَّى الْأَثَرَا

329
00:15:18,029 --> 00:15:20,849
وَلِلْعِثَارِ نَسَقٌ فِي سَيْرِهِ

330
00:15:20,909 --> 00:15:24,250
لَيْسَ يُبَالِي حُفَرًا أَوْ حَجَرَا

331
00:15:24,310 --> 00:15:27,089
وَكَمْ عِثَارٍ مَا لَهُ مِنْ بَاعِثٍ

332
00:15:27,149 --> 00:15:29,370
وَإِنَّمَا بَدَا لَهُ فَعَثَرَا

333
00:15:29,430 --> 00:15:32,109
وَانْظُرْ إِلَى الْأَمْثَالِ فِي مَضْرِبِهَا

334
00:15:32,229 --> 00:15:34,729
بِهِ، وَكَمْ مِنْ مَثَلٍ بِهِ جَرَى

335
00:15:34,789 --> 00:15:37,890
حَسْبُكَ فِي الْوَحْيَيْنِ كَمْ جَاءَ بِهِ

336
00:15:37,950 --> 00:15:40,330
مِنْ آيَةٍ، وَكَمْ حَدِيثٍ سُطِرَا

337
00:15:40,390 --> 00:15:43,130
وَانْظُرْ إِلَيْهِ فَرَّ مِنْ قَسْوَرَةٍ

338
00:15:43,190 --> 00:15:45,450
وَقَدْ تَوَلَّى مُدْبِرًا مُسْتَنْفِرَا

339
00:15:45,510 --> 00:15:48,409
كَمَا بِهِ قَدْ ضُرِبَ الْمَثَلُ فِي

340
00:15:48,469 --> 00:15:51,310
إِعْرَاضِهِ عَمَّا بِهِ قَدْ ذُكِّرَا

341
00:15:52,550 --> 00:15:55,209
لَوْ كَانَ فِيهِ لِلْقَبُولِ مَوْضِعٌ

342
00:15:55,269 --> 00:15:57,969
مَا جَاءَ فِي الْقُرْآنِ: "إِنَّ أَنْكَرَا"

343
00:15:58,029 --> 00:16:00,330
أَلَيْسَ يَقْطَعُ الصَّلَاةَ نَاهِقًا

344
00:16:00,390 --> 00:16:03,250
وَيُسْتَعَاذُ عِنْدَهُ إِذَا انْبَرَى

345
00:16:03,310 --> 00:16:06,529
يَا شَيْخُ يَحْيَى هَذِهِ قَضِيَّتِي

346
00:16:06,589 --> 00:16:10,169
مَعَ الْحِمَارِ مَوْرِدًا وَمَصْدَرَا

347
00:16:10,229 --> 00:16:13,750
قَرَأْتُ فِي آدَابِنَا مِنْ ذَمِّهِ

348
00:16:13,950 --> 00:16:17,270
بَدَائِعًا مِنْ حَقِّهَا أَنْ تُشْهَرَا

349
00:16:17,390 --> 00:16:20,450
فَكَمْ هَجَاهُ مَنْ هَجَا مِنْ شَاعِرٍ

350
00:16:20,510 --> 00:16:23,409
وَكَمْ حَكِيمٍ عَنْ حِمَاهُ نَفَرَا

351
00:16:23,469 --> 00:16:25,690
فَقِيلَ فِي رَاكِبِهِ: "سَوْفَ تَرَى

352
00:16:25,750 --> 00:16:28,989
إِذَا انْجَلَى الْغُبَارُ" مَا سَوْفَ تَرَى

353
00:16:30,029 --> 00:16:32,409
إِنِ الْحِوَارُ وَالْحِمَارُ اصْطَحَبَا

354
00:16:32,469 --> 00:16:35,330
فِي السَّيْرِ أَلْفَيْتَ الْحِوَارَ اسْتَحْمَرَا

355
00:16:35,390 --> 00:16:38,010
وَصَارَ مِنْ بَعْدِ الرُّغَاءِ شَاهِقًا

356
00:16:38,070 --> 00:16:40,220
وَنَاهِقًا، سُرْعَانَ مَا تَأَثَّرَا

357
00:16:40,469 --> 00:16:42,849
وَلَكَ فِي حِمَارِ تُومَا مَثَلٌ

358
00:16:42,909 --> 00:16:45,849
إِذْ قَالَ عَنْ رَاكِبِهِ مَا أُثِرَا

359
00:16:45,909 --> 00:16:48,570
مَقَالَةً عَنْهُ حَكَاهَا مَنْ حَكَى

360
00:16:48,630 --> 00:16:50,810
عَلَى لِسَانِ حَالِهِ مُعَبِّرَا:

361
00:16:50,870 --> 00:16:53,529
"لَوْ أَنْصَفُونِي" قَالَ مَا كُنْتُ أَنَا

362
00:16:53,589 --> 00:16:57,429
أَحَقَّ أَنْ أُرْكَبَ إِذْ أَنَا بَرَا!

363
00:16:58,950 --> 00:17:00,810
لِأَنَّ جَهْلِيَ بَسِيطٌ وَالَّذِي

364
00:17:00,870 --> 00:17:03,370
يَرْكَبُنِي بِالْجَهْلِ قَدْ تَدَثَّرَا!

365
00:17:03,430 --> 00:17:06,130
إِنَّ الْحِمَارَ مُعْرِقٌ فِي جِنْسِهِ

366
00:17:06,190 --> 00:17:09,189
كَانَ أَصِيلَ الْعِرْقِ أَوْ تَحَمَّرَا

367
00:17:09,269 --> 00:17:11,870
لَا يَقْبَلُ الْمَجَازَ فِي تَشْبِيهِهِ

368
00:17:11,950 --> 00:17:14,610
وَهَبْهُ قِيلَ: "الْعَيْرُ" أَوْ قِيلَ: "الْفَرَا"

369
00:17:14,670 --> 00:17:17,170
وَهْوَ حِمَارٌ كَيْفَمَا قَلَّبْتَهُ

370
00:17:17,230 --> 00:17:19,890
وَلَوْ تَتَوَّجَ بِتَاجِ قَيْصَرَا!

371
00:17:19,950 --> 00:17:22,130
أَرَى الْخَلِيلَ فِي الْعَرُوضِ عَدَّهُ

372
00:17:22,190 --> 00:17:24,770
وَلَمْ يُرَاعِ ضَعْفَهُ وَالْخَوَرَا

373
00:17:24,830 --> 00:17:27,170
"مُسْتَفْعِلُنْ مُسْتَفْعِلُنْ مُسْتَفْعِلُنْ"

374
00:17:27,230 --> 00:17:29,929
رَكْضُ الْحِمَارِ وَزْنُهُ إِذَا جَرَى

375
00:17:29,989 --> 00:17:32,490
فَمَنْ تَرَاهُ عَاجِزًا عَنْ نَظْمِهِ

376
00:17:32,550 --> 00:17:34,850
وَلَوْ أَرَادَ الْأَلْفَ مِنْهَا اسْتَيْسَرَا

377
00:17:34,910 --> 00:17:37,730
فَإِنْ يَكُنْ "مُسْتَفْعِلُنْ مُسْتَفْعِلُنْ"

378
00:17:37,790 --> 00:17:40,370
شِعْرًا، فَكُلُّ النَّاسِ صَارُوا شُعَرَا!

379
00:17:40,430 --> 00:17:42,970
لِذَاكَ قَدْ رَكِبَهُ النُّظَّامُ فِي

380
00:17:43,030 --> 00:17:44,970
أَنْظَامِهِمْ وَلَمْ يُطِيلُوا الْفِكَرَا

381
00:17:45,030 --> 00:17:46,970
فَكَثُرَتْ حَمِيرُهُمْ، وَزَاحَمَتْ

382
00:17:47,030 --> 00:17:50,189
أَهْلَ الْقَرِيضِ وَالْقَصِيدِ بِالْهُرَا

383
00:17:51,310 --> 00:17:53,569
لَا تَأْمَنِ الْحَمِيرَ فِي رُكُوبِهَا

384
00:17:53,629 --> 00:17:56,010
وَلَا تَقُلْ فِيهَا: رَكُوبُ الْفُقَرَا

385
00:17:56,070 --> 00:17:58,490
فَكَمْ فَقِيرٍ قَصَمَتْ فَقَارَهُ

386
00:17:58,550 --> 00:18:01,170
فَمَا تَوَلَّى الْيَوْمُ حَتَّى أُقْبِرَا

387
00:18:01,230 --> 00:18:03,449
وَسَقْطَةٍ عَنِ الْجَوَادِ سَلِمَتْ

388
00:18:03,509 --> 00:18:05,970
وَسَقْطَةُ الْحِمَارِ دَقَّتِ الْقَرَا

389
00:18:06,030 --> 00:18:08,929
فَلَا تَقُلْ لِي فِي حِمَارٍ: "فَارِهٌ!"

390
00:18:08,989 --> 00:18:11,270
فَكُلُّهَا مَهْمَا تَفَرَّهَ فَرَا

391
00:18:11,749 --> 00:18:13,970
لَوْ لَبِسَ الْحِمَارُ ثَوْبَ حَبْرَةٍ

392
00:18:14,030 --> 00:18:16,290
كَانَ حِمَارًا قَدْ تَرَدَّى الْحِبَرَا

393
00:18:16,350 --> 00:18:18,770
أَوْ قَدْ جَرَى مَعَ الْجِيَادِ غَلْوَةً

394
00:18:18,830 --> 00:18:21,410
قِيلَ: حِمَارٌ فِي السِّبَاقِ غَبَّرَا

395
00:18:21,470 --> 00:18:24,010
جَاءَ أَخِيرًا وَهْوَ يَشْكُو حَظَّهُ

396
00:18:24,070 --> 00:18:27,230
يَرَى لِسُوءِ حَظِّهِ تَأَخَّرَا

397
00:18:27,280 --> 00:18:30,010
يَرَى لِسُوءِ حَظِّهِ تَأَخَّرَا

398
00:18:30,190 --> 00:18:32,689
وَأَنَّ مَنْ يُعْلِفُهُ مُقَصِّرٌ

399
00:18:32,749 --> 00:18:35,490
فِي حَقِّهِ فَهْوَ لِذَاكَ قَصَّرَا

400
00:18:35,550 --> 00:18:38,330
فَالشُّؤْمُ فِي ثَلَاثَةٍ إِنْ كَانَ فَهْـ

401
00:18:38,390 --> 00:18:41,850
ـوَ وَاحِدٌ فِيمَا نَعُدُّهُ يُرَى

402
00:18:41,910 --> 00:18:44,530
لَا تَرْكَبِ الْحِمَارَ يَوْمًا إِنَّهُ

403
00:18:44,590 --> 00:18:47,130
بِئْسَ الْمَطِيَّةُ لِمَنْ لَهُ عَرَا!

404
00:18:47,190 --> 00:18:49,530
وَلَا تَثِقْ إِذَا بَدَا مُسَالِمًا

405
00:18:49,590 --> 00:18:52,630
فَالنَّارُ قَبْلَ الْوَقْدِ كَانَتْ شَجَرَا!

406
00:18:53,350 --> 00:18:55,650
وَلَا تَقُلْ فِي رَجَزٍ: "شِعْرٌ!" فَلَوْ

407
00:18:55,710 --> 00:18:58,330
كَانَ لَمَا قِيلَ: "حِمَارُ الشُّعَرَا"

408
00:18:58,390 --> 00:19:01,049
لَا تَأْمَنِ الْعَيْرَ فَرُبَّمَا هَوَى

409
00:19:01,109 --> 00:19:02,779
بِرَاكِبٍ فَدَقَّ مِنْهُ الْمِنْخَرَا!

410
00:19:03,350 --> 00:19:05,610
لَمْ يَرْعَ فِيهِ ذِمَّةً أَوْ صُحْبَةً

411
00:19:05,670 --> 00:19:08,809
وَلَوْ غَذَاهُ أَشْهُرًا وَأَشْهُرَا

412
00:19:08,869 --> 00:19:11,530
يُعْلِفُهُ مِنْ قُوتِهِ وَيَقْتَنِي

413
00:19:11,590 --> 00:19:14,709
لَهُ الْإِكَافَ وَالْمَخَالِي الْأَوْفَرَا

414
00:19:14,799 --> 00:19:17,699
وَكَانَ يَسْتَوْصِي بِهِ فِي ظَهْرِهِ

415
00:19:17,749 --> 00:19:20,250
وَكَانَ يَسْتَوْصِي بِهِ فِي ظَهْرِهِ

416
00:19:20,310 --> 00:19:22,890
فَلَا يُحَمَّلُ سِوَى مَا قَدَرَا

417
00:19:22,950 --> 00:19:25,490
وَلَيْسَ يُرْدِفُ عَلَيْهِ رَاكِبًا

418
00:19:25,550 --> 00:19:28,290
مِنْ خَلْفِهِ مِنْ رَجُلٍ أَوْ مِنْ مَرَا

419
00:19:28,350 --> 00:19:30,250
لَكِنَّمَا الْعَيْرُ لِسُوءِ طَبْعِهِ

420
00:19:30,310 --> 00:19:33,150
لَا يَعْقِلُ الْجَمِيلَ مَهْمَا كَثُرَا

421
00:19:34,509 --> 00:19:37,010
وَلَا يُبَالِي صَرْعَةً أَوْ رَفْسَةً

422
00:19:37,070 --> 00:19:39,809
تَغْدُو بِهَا عَلَى الثَّرَى مُعَثَّرَا

423
00:19:39,869 --> 00:19:42,410
وَرُبَّمَا زَادَ فِرَارًا بَعْدَمَا

424
00:19:42,470 --> 00:19:45,049
فَعَلَهَا وَطَاشَ عَنْكَ مَنْظَرَا

425
00:19:45,109 --> 00:19:47,170
ثُمَّ رَمَى إِكَافَهُ وَخُرْجَهُ

426
00:19:47,230 --> 00:19:49,530
وَمَا حَمَلْتَ فِيهِ فِي عُرْضِ الثَّرَى

427
00:19:49,590 --> 00:19:51,730
إِنَّ الْحِمَارَ لَأَمِيرُ نَفْسِهِ

428
00:19:51,790 --> 00:19:54,290
وَلَوْ تَأَدَّبْتَ لَهُ مَا شَعَرَا!

429
00:19:54,350 --> 00:19:56,770
وَلَوْ تَخَيَّرْتَ لَهُ بَرْدَعَةً

430
00:19:56,830 --> 00:19:59,490
مِنْ نَسْجِ صَنْعَاءَ وَوَشْيِ عَبْقَرَا

431
00:19:59,550 --> 00:20:01,490
وَلَمْ يَزَلْ فِي جِنْسِهِ مُمْتَهَنًا

432
00:20:01,550 --> 00:20:04,030
كَمَا أَرَاهُ فِي حِمَارِ الشُّعَرَا

433
00:20:04,080 --> 00:20:06,460
وَلَيْسَ هَجْوِي لِلْحِمَارِ غَايَتِي

434
00:20:06,520 --> 00:20:09,579
كَانَ حِمَارَ الشِّعْرِ أَوْ كَانَ فَرَا

435
00:20:09,629 --> 00:20:12,090
وَلَيْسَ هَجْوِي لِلْحِمَارِ غَايَتِي

436
00:20:12,150 --> 00:20:14,610
كَانَ حِمَارَ الشِّعْرِ أَوْ كَانَ فَرَا

437
00:20:14,670 --> 00:20:16,929
وَإِنَّمَا جَعَلْتُهُ وَسِيلَةً

438
00:20:16,989 --> 00:20:19,569
أُمَلِّحُ الْجِدَّ بِهَا إِذَا عَرَا

439
00:20:19,629 --> 00:20:22,210
فَفِي زَمَانِ الْجِدِّ تَحْلُو سَاعَةٌ

440
00:20:22,270 --> 00:20:24,569
لِلْهَزْلِ يَمْرَحُ بِهَا مَنْ سَمَرَا

441
00:20:24,629 --> 00:20:26,929
فَنَمَطُ الْقَوْلِ عَلَى وَتِيرَةٍ

442
00:20:26,989 --> 00:20:29,990
يَمَلُّ مِنْهُ مَنْ بَدَا أَوْ حَضَرَا

443
00:20:31,030 --> 00:20:33,569
فَخُذْ إِلَيْكَ هَذِهِ تَكْمِلَةً

444
00:20:33,629 --> 00:20:36,049
فِي رَجَزٍ طَلَّقْتُ فِيهِ الْأَبْحُرَا

445
00:20:36,109 --> 00:20:39,170
جَبْرًا لِخَاطِرِ أَدِيبٍ بَارِعٍ

446
00:20:39,230 --> 00:20:41,929
أَحَبَّهُ فَقُلْتُ فِيهِ مَا تَرَى

447
00:20:41,989 --> 00:20:43,970
ثُمَّ أَنَا أَسْتَغْفِرُ اللَّهَ لِمَا

448
00:20:44,030 --> 00:20:47,010
مِنِّيَ مِنْ هَزْلٍ بَرِيءٍ صَدَرَا

449
00:20:47,070 --> 00:20:49,569
وَقَائِلٌ خِتَامَ مَا دَبَّجْتُهُ

450
00:20:49,629 --> 00:20:52,770
صَلَّى وَسَلَّمَ عَلَى خَيْرِ الْوَرَى

451
00:20:52,830 --> 00:20:55,370
مُحَمَّدٍ وَآلِهِ وَصَحْبِهِ

452
00:20:55,430 --> 00:20:58,850
ثُمَّ عَلَيْكُمْ مَعْشَرًا فَمَعْشَرَا
